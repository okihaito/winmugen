[Statedef 4000] 
physics = N                      
sprpriority = 2 ; Spawn behind the player. Typical player sprpriority doesn't go below 0.  
 
[State 4000, ChangeAnim]
type = ChangeAnim
trigger1 = 1 || anim != root,anim ; Safety! 
value = root,Anim
elem = root,Animelemno(0) ; Capture the player's animelem
 
[State 4000, BindToRoot]
type = BindToRoot ; This is to ensure the proper position for the helper.
trigger1 = 1 
ignorehitpause = 1
 
[State 4000, AngleDraw]
type = AngleDraw
trigger1 = 1
scale = 1 + .015*(gametime%32), 1 + .015*(gametime%32) ; Adjust the decimal value to control the size of the "Afterimage"
 
[State 4000, Trans]
type = Trans
trigger1 = 1
trans = addalpha
alpha = 256 - 8*(gametime%32), 8*(gametime%32)  ; You can decrease the integer that is next to the multiplication symbol to control the fading of the "Afterimage".
persistent = 1
 
[State 4000, DestroySelf]
type = DestroySelf
trigger1 = time > 100 ; Destroy after 6 ticks to respawn and recreate time! You can increase this value to increase the life of the "Afterimage".
trigger2 = root,movetype = H ; Prevent custom state angle stuff

