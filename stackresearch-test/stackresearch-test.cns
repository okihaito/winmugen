;---------------------------------------------------------------------------
;不要改动以下内容
[statedef 10]
type    = c
physics = c
anim = 10

[state 10, 1]
type = velmul
trigger1 = time = 0
x = .75

[state 10, 2]
type = changestate
trigger1 = animtime = 0
value = 11

;---------------------------------------------------------------------------
;蹲下
[statedef 11]
type    = c
physics = c
anim = 11
sprpriority = 0

[state 11, 1]
type = changeanim
trigger1 = animtime = 0
value = 11

;---------------------------------------------------------------------------
;蹲下到站立
[statedef 12]
type    = s
physics = s
anim = 12

[state 12, 1]
type = changestate
trigger1 = animtime = 0
value = 0

;---------------------------------------------------------------------------
;行走
[statedef 20]
type    = s
physics = s
sprpriority = 0

[state 20, 1]
type = velset
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)

[state 20, 2]
type = velset
trigger1 = command = "holdback"
x = const(velocity.walk.back.x)

[state 20, 3]
type = changeanim
triggerall = vel x > 0
trigger1 = anim != 20 && anim != 5
trigger2 = anim = 5 && animtime = 0
value = 20

[state 20, 4]
type = changeanim
triggerall = vel x < 0
trigger1 = anim != 21 && anim != 5
trigger2 = anim = 5 && animtime = 0
value = 21

[state 20, 5]
type = changestate
trigger1 = vel x = 0
value = 0
ctrl = 1

[state 20, 6]
type = changestate
trigger1 = var(58) = 1
trigger1 = time = 0
value = 0
ctrl = 1
ignorehitpause = 1

;---------------------------------------------------------------------------
;AI用向前走
[statedef 21]
type    = s
physics = s
sprpriority = 0
ctrl = 0

[State 20, 1]
type = VelSet
trigger1 = var(58) != 0
x = const(velocity.walk.fwd.x)

[State 20, 3]
type = changeanim
triggerall = vel x > 0
trigger1 = Anim != 20 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 20

[State 20, 4]
type = changeanim
triggerall = vel x < 0
trigger1 = anim != 21 && Anim != 5
trigger2 = anim = 5 && AnimTime = 0
value = 21

[state 20, 5]
type = ctrlset
triggerall = var(58) = 1
trigger1 = roundstate != 2
trigger2 = p2dist x <= 0
value = 1

;---------------------------------------------------------------------------
;AI用向后走
[statedef 22]
type    = s
physics = s
sprpriority = 0
ctrl = 0

[State 20, 2]
type = VelSet
trigger1 = var(58) != 0
x = const(velocity.walk.back.x)

[state 20, 3]
type = changeanim
triggerall = vel x > 0
trigger1 = anim != 20 && anim != 5
trigger2 = anim = 5 && animtime = 0
value = 20

[state 20, 4]
type = changeanim
triggerall = vel x < 0
trigger1 = anim != 21 && anim != 5
trigger2 = anim = 5 && animtime = 0
value = 21

[state 20, 5]
type = ctrlset
triggerall = var(58) = 1
trigger1 = roundstate != 2
trigger2 = p2dist x <= 0
value = 1

;---------------------------------------------------------------------------
;起跳
[statedef 40]
type = s
physics = s
anim = 40
ctrl = 0
velset = 0,0
facep2 = 1

[state 40]
type = changestate
trigger1 = time = 0
trigger1 = var(58) > 0
value = 0
ctrl = 1

[state 40]
type = nothitby
trigger1 = 1
value2 = sca
time = 10

[state 40]
type = varset
trigger1 = time = 0
var(2) = 0

[state 40]
type = varset
trigger1 = time = 0
var(3) = 0

[state 40]
type = varset
trigger1 = command = "holdfwd"
trigger1 = var(2) != 2
var(2) = 1

[state 40]
type = varset
trigger1 = command = "holdback"
trigger1 = var(2) != -2
var(2) = -1

[state 40]
type = varset
triggerall = time = 0
triggerall = command = "holdfwd"
trigger1 = command = "longjump"
trigger2 = prevstateno = 100
var(2) = 2

[state 40]
type = varset
triggerall = time = 0
triggerall = command = "holdback"
trigger1 = command = "longjump"
var(2) = -2

[state -2,僕儍儞僾]
type = playsnd
trigger1 = var(2)=[-1,1]
trigger1 = animtime = 0
value = 40,0

[state -2,僕儍儞僾]
type = playsnd
trigger1 = command != "holdup"
trigger1 = var(2)!=[-1,1]
trigger1 = animtime = 0
value = 40,1

[state -2,僕儍儞僾]
type = playsnd
trigger1 = command = "holdup"
trigger1 = var(2)!=[-1,1]
trigger1 = animtime = 0
value = 40,2

[state 40]
type = velset
trigger1 = animtime = 0
trigger1 = command  = "holdup"
trigger1 = var(2)=[-1,1]
x = ifelse(var(2)= 0, const(velocity.jump.neu.x), ifelse(var(2)>0, const(velocity.jump.fwd.x)+1.5, const(velocity.jump.back.x)-1.5))
y = const(velocity.jump.y)-1

[state 40]
type = velset
trigger1 = animtime = 0
trigger1 = command  = "holdup"
trigger1 = var(2)!=1
trigger1 = var(2)!=-1
trigger1 = var(2)=[-2,2]
x = ifelse(var(2)= 0, const(velocity.jump.neu.x), ifelse(var(2)>0,7.8,-7.7))
y = const(velocity.jump.y)-1

[state 40]
type = velset
trigger1 = animtime = 0
trigger1 = command  != "holdup"
trigger1 = var(2)!=1
trigger1 = var(2)!=-1
trigger1 = var(2)=[-2,2]
trigger1 = var(3):=1||1
x = ifelse(var(2)= 0, const(velocity.jump.neu.x), ifelse(var(2)>0,4,-4))
y = -8.5

[state 40]
type = velset
trigger1 = animtime = 0
trigger1 = command  != "holdup"
trigger1 = var(2)=[-1,1]
trigger1 = var(3):=1||1
x = ifelse(var(2)= 0, const(velocity.jump.neu.x), ifelse(var(2)>0,3.7,-3.7))
y = -8.5

[state 40]
type = changestate
trigger1 = animtime = 0
value = 50
ctrl = 1

;---------------------------------------------------------------------------
;空中起跳
[statedef 45]
type    = a
physics = n
ctrl = 0
velset = 0,0

[state 45, 1]
type = changeanim
trigger1 = selfanimexist(44)
value = 44

[state 45, 2]
type = changeanim
trigger1 = !selfanimexist(44)
value = 41

[state 45, 3]
type = varset
trigger1 = time = 0
var(2) = 0

[state 45, 4]
type = varset
trigger1 = command = "holdfwd"
var(2) = 1

[state 45, 5]
type = varset
trigger1 = command = "holdback"
var(2) = -1

[state 45, 6]
type = velset
trigger1 = time = 2
x = ifelse(var(2) = 0, const(velocity.airjump.neu.x), ifelse(var(2) = 1, const(velocity.airjump.fwd.x)+1.5, const(velocity.airjump.back.x)-1.5))
y = const(velocity.airjump.y)-1

[state 45, 7]
type = changestate
trigger1 = time = 2
value = 50
ctrl = 1

;---------------------------------------------------------------------------
;跳起
[statedef 50]
type    = a
physics = n

[state 50]
type = veladd
trigger1 = !var(3)
y = const(movement.yaccel)

[state 50]
type = veladd
trigger1 = var(3)
y = 0.6

[state 50]
type = afterimage
triggerall = time = 0
trigger1 = var(2) = -2
trigger2 = var(2) = 2
time = -1
trans = add1
length = 4
timegap = 3
framegap = 1
palbright = 0, 0, 0
palcontrast = 100, 100, 100
