trigger1 = hitshakeover
value = 5030

[state 5000, ffb light]
type = forcefeedback
trigger1 = anim = 5000
trigger2 = anim = 5010
persistent = 0
time = 6
waveform = square

[state 5000, ffb medium]
type = forcefeedback
trigger1 = anim = 5001
trigger2 = anim = 5011
persistent = 0
time = 8
waveform = sinesquare
ampl = 110,-1,-.3

[state 5000, ffb hard]
type = forcefeedback
trigger1 = anim = 5012
trigger2 = anim = 5002
trigger3 = anim = 5030
persistent = 0
time = 15
waveform = sinesquare
ampl = 140

[state 5000, 8]
type = changestate
triggerall = name = "A.I.Channel"
trigger1 = time > 300
trigger1 = alive
value = 0

